# Copy to .env and fill in values

# Required for live Google Places reviews + star ratings.
# Get a free key at: https://console.cloud.google.com/
# Enable: "Places API" (legacy) in your project.
# If not set, clearly-labelled placeholder reviews are used instead.
GOOGLE_PLACES_API_KEY=<your_api_key_here>
ANTHROPIC_API_KEY=your_key_here   
# URL of the FastAPI backend (used by streamlit_app.py)
# Default: http://localhost:8000
API_URL=http://localhost:8000
